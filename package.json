{
  "name": "@airpoint/sdk",
  "version": "0.1.0",
  "description": "Browser-first Airpoint plugin runtime for touchless computing",
  "license": "Apache-2.0",
  "author": "Airpoint",
  "keywords": [
    "airpoint",
    "touchless",
    "cursor",
    "hand-tracking",
    "gesture",
    "mediapipe",
    "plugin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marioandf/airpoint-sdk.git"
  },
  "homepage": "https://github.com/marioandf/airpoint-sdk#readme",
  "bugs": {
    "url": "https://github.com/marioandf/airpoint-sdk/issues"
  },
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    }
  },
  "bin": {
    "airpoint-sdk-copy-assets": "./scripts/copy-assets.mjs",
    "airpoint-sdk-pack-premium-assets": "./scripts/pack-premium-assets.mjs",
    "airpoint-sdk-sign-premium-license": "./scripts/sign-premium-license.mjs"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && node scripts/fix-dist-esm-imports.mjs dist",
    "copy-assets": "node scripts/copy-assets.mjs",
    "dev:example": "pnpm --filter @airpoint/basic-example dev",
    "pack:local": "pnpm pack --pack-destination .pack",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.22-rc.20250304",
    "onnxruntime-web": "^1.23.2"
  },
  "files": [
    "dist",
    "assets",
    "scripts",
    "CHANGELOG.md",
    "NOTICES.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "workspaces": [
    "examples/*"
  ],
  "devDependencies": {
    "happy-dom": "^20.3.0",
    "vite": "^6.4.1",
    "vitest": "^4.0.17",
    "typescript": "^5.9.3"
  }
}
